# ===========================================
# Ambient Context MCP Server Configuration
# ===========================================

# Vault location (defaults to parent of mcp-server directory)
# VAULT_PATH=~/my-vault

# Server configuration
MCP_SERVER_PORT=9000
MCP_SERVER_HOST=0.0.0.0

# Claude CLI path (if not in PATH)
CLAUDE_CLI_PATH=claude

# ===========================================
# Authentication
# ===========================================

# Disable auth entirely (for Tailscale/local network use)
# Can also be set via ./start.sh --no-auth
NO_AUTH=true

# ===========================================
# Auth0 OAuth Configuration (Optional)
# ===========================================
# Only used when NO_AUTH is not set or false.

# Auth0 tenant domain (from Auth0 dashboard)
# AUTH0_DOMAIN=your-tenant.auth0.com

# API identifier (audience) - must match Auth0 API configuration
# AUTH0_AUDIENCE=https://your-api-identifier

# Required scopes for access (comma-separated)
# AUTH0_REQUIRED_SCOPES=read:vault

# Allowed users (comma-separated Auth0 subject IDs)
# AUTH0_ALLOWED_USERS=

# ===========================================
# Legacy API Key (Optional Fallback)
# ===========================================

# Enable API key fallback for local development
# ALLOW_API_KEY_FALLBACK=false

# API key for legacy/local access (only used if fallback enabled)
# VAULT_MCP_API_KEY=your-secure-api-key-here
